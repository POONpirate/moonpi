[Unit]
Description=Switch to tty2 on boot
DefaultDependencies=no
After=moonpi@tty2.service
# On desktop systems moonpi waits for the compositor then switches itself,
# to avoid racing lightdm's VT management. Only run this on headless systems.
ConditionPathExists=!/etc/systemd/system/display-manager.service

[Service]
Type=oneshot
ExecStart=/bin/chvt 2

[Install]
WantedBy=multi-user.target
