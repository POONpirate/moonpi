#!/usr/bin/env bash
# moonlight-launch.sh — interactive launcher with pre-launch menu,
#                     unified config handling and modular configurator().

set -euo pipefail

if (( EUID == 0 )); then
  IS_ROOT=true
else
  IS_ROOT=false
fi

#— ANSI colors ----------------------------------------------------------------
RED="$(tput setaf 1)";    GREEN="$(tput setaf 2)"
YELLOW="$(tput setaf 3)"; BLUE="$(tput setaf 4)"
BOLD="$(tput bold)";      RESET="$(tput sgr0)"

#— Config paths ---------------------------------------------------------------
SYSTEM_CFG=${MOONPI_CONFIG_PATH:-/etc/moonpi/moonpi.conf}
USER_CFG=${XDG_CONFIG_HOME:-$HOME/.config}/moonpi/moonpi.conf


#— Functions ------------------------------------------------------------------

# Load system config, then overlay user config if present
read_config() {
  if [[ -r $SYSTEM_CFG ]]; then
    source "$SYSTEM_CFG"
  else
    echo "Error: cannot read system config at $SYSTEM_CFG" >&2
    exit 1
  fi

  if [[ -r $USER_CFG ]]; then
    source "$USER_CFG"
  fi
}

# Saves the config as SYSTEM_CFG if root, if not saves USER_CFG
write_config() {
  if [[ $IS_ROOT == true ]]; then
    target_cfg="$SYSTEM_CFG"
  else
    target_cfg="$USER_CFG"
  fi

  # Ensure the parent directory exists
  mkdir -p "$(dirname "$target_cfg")"

  tee "$target_cfg" > /dev/null <<EOF
HOST_IP="${HOST_IP:-}"
APP_NAME="${APP_NAME:-}"
FPS="${FPS:-}"
BITRATE="${BITRATE:-}"
RESOLUTION_FLAG="${RESOLUTION_FLAG:-}"
CUSTOM_WIDTH="${CUSTOM_WIDTH:-}"
CUSTOM_HEIGHT="${CUSTOM_HEIGHT:-}"
LOCAL_AUDIO="${LOCAL_AUDIO:-}"
EOF

  chmod 644 "$target_cfg"
  echo "✅ Config saved to $target_cfg"
}

# Create a user config from current values if one doesn't exist yet
ensure_user_cfg() {
  if [[ ! -f $USER_CFG ]]; then
    mkdir -p "$(dirname "$USER_CFG")"
    write_config
	draw_banner
    echo "${YELLOW}ℹ️  No user config found — created one at $USER_CFG${RESET}"
    sleep 4
  fi
}

# Interactive configuration routine — per-option submenu
configurator() {
  while true; do
    draw_cfg_banner

    # Format resolution for display
    case "${RESOLUTION_FLAG:-}" in
      -720)  res_display="720p"  ;;
      -1080) res_display="1080p" ;;
      -4k)   res_display="4K"   ;;
      "")    res_display="Custom (${CUSTOM_WIDTH:-?}x${CUSTOM_HEIGHT:-?})" ;;
      *)     res_display="${RESOLUTION_FLAG}" ;;
    esac

    echo "${BLUE}🛠️  MoonPi Configuration${RESET}"
    echo
    echo "${GREEN} 1)${RESET} Host IP       ${YELLOW}[${HOST_IP:-}]${RESET}"
    echo "${GREEN} 2)${RESET} App Name      ${YELLOW}[${APP_NAME:-}]${RESET}"
    echo "${GREEN} 3)${RESET} Resolution    ${YELLOW}[${res_display}]${RESET}"
    echo "${GREEN} 4)${RESET} FPS           ${YELLOW}[${FPS:-}]${RESET}"
    echo "${GREEN} 5)${RESET} Bitrate       ${YELLOW}[${BITRATE:-}]${RESET}"
    echo "${GREEN} 6)${RESET} Local Audio   ${YELLOW}[${LOCAL_AUDIO:-}]${RESET}"
    echo "${GREEN} 7)${RESET} Back"
    echo
    read -p "${BLUE}Choose [1–7]: ${RESET}" cfg_choice

    case $cfg_choice in
      1)  # Host IP
        read -p "➡ Enter host IP [${HOST_IP}]: " input
        HOST_IP=${input:-$HOST_IP}
        write_config; sleep 1
        ;;

      2)  # App Name — try to discover from host first
        echo
        echo "➡ Discovering apps on ${HOST_IP}…"
        mapfile -t APPS < <(
          moonlight list "$HOST_IP" 2>/dev/null \
            | sed -n '2,$p' | sed -E 's/^[[:space:]]*[0-9]+\.[[:space:]]*//'
        )
        if (( ${#APPS[@]} )); then
          echo "${YELLOW}Available apps:${RESET}"
          PS3=$'\nChoose an app [1-'$((${#APPS[@]}+1))']: '
          select choice in "${APPS[@]}" "Enter manually"; do
            if (( REPLY >= 1 && REPLY <= ${#APPS[@]} )); then
              APP_NAME="$choice"; break
            elif (( REPLY == ${#APPS[@]}+1 )); then
              read -p "➡ Enter app name manually: " APP_NAME; break
            else
              echo "${RED}Invalid selection.${RESET}"
            fi
          done
        else
          echo "${YELLOW}⚠️  Could not fetch app list, falling back to manual entry${RESET}"
          read -p "➡ Enter app name [${APP_NAME}]: " input
          APP_NAME=${input:-$APP_NAME}
        fi
        write_config; sleep 1
        ;;

      3)  # Resolution
        echo
        echo "${BLUE}Select resolution:${RESET}"
        echo "  ${YELLOW}1)${RESET} 720p"
        echo "  ${YELLOW}2)${RESET} 1080p"
        echo "  ${YELLOW}3)${RESET} 4K"
        echo "  ${YELLOW}4)${RESET} Custom"
        read -p "${GREEN}Choose [1–4]: ${RESET}" res_choice
        case $res_choice in
          1)
            RESOLUTION_FLAG="-720"
            CUSTOM_WIDTH=""; CUSTOM_HEIGHT=""
            width_flag=(); height_flag=()
            ;;
          2)
            RESOLUTION_FLAG="-1080"
            CUSTOM_WIDTH=""; CUSTOM_HEIGHT=""
            width_flag=(); height_flag=()
            ;;
          3)
            RESOLUTION_FLAG="-4k"
            CUSTOM_WIDTH=""; CUSTOM_HEIGHT=""
            width_flag=(); height_flag=()
            ;;
          4)
            read -p "${GREEN}  → width [${CUSTOM_WIDTH:-2560}]: ${RESET}" w
            read -p "${GREEN}  → height [${CUSTOM_HEIGHT:-1440}]: ${RESET}" h
            CUSTOM_WIDTH=${w:-${CUSTOM_WIDTH:-2560}}
            CUSTOM_HEIGHT=${h:-${CUSTOM_HEIGHT:-1440}}
            RESOLUTION_FLAG=""
            width_flag=(-width "$CUSTOM_WIDTH")
            height_flag=(-height "$CUSTOM_HEIGHT")
            ;;
          *)
            echo "${YELLOW}Invalid choice, resolution unchanged.${RESET}"
            sleep 1
            continue
            ;;
        esac
        write_config; sleep 1
        ;;

      4)  # FPS
        read -p "➡ Enter FPS [${FPS}]: " input
        FPS=${input:-$FPS}
        write_config; sleep 1
        ;;

      5)  # Bitrate
        read -p "➡ Enter bitrate in kbps [${BITRATE}]: " input
        BITRATE=${input:-$BITRATE}
        write_config; sleep 1
        ;;

      6)  # Local Audio
        read -p "➡ Use local audio? (y/N) [current: ${LOCAL_AUDIO}]: " la
        la=${la,,}
        if [[ $la =~ ^(y|yes)$ ]]; then LOCAL_AUDIO="yes"; else LOCAL_AUDIO="no"; fi
        write_config; sleep 1
        ;;

      7)  # Back
        return
        ;;

      *)
        echo "${YELLOW}Invalid selection.${RESET}"
        sleep 1
        ;;
    esac
  done
}

# A section to pair moonlight.
pair_moonlight() {
  # Prompt, with HOST_IP as the default
  read -p "What IP would you like to pair with? Default: ${HOST_IP}: " ip
  ip=${ip:-$HOST_IP}

  echo "${BLUE}▶ Pairing with $ip…${RESET}"
  if moonlight pair "$ip"; then
    echo "${GREEN}✔ Pairing succeeded!${RESET}"
  else
    echo "${RED}✖ Pairing failed.${RESET}"
  fi

  # Pause so the user can read the result
  read -p "Press ENTER to return to menu…"
}

#Banner
draw_banner() {
  clear
  # https://patorjk.com/software/taag/#p=display&f=Larry%203D&t=MoonPi%20Launcher
  printf "%s" "${BOLD}${BLUE}"
  cat <<'MOONPI'
                                 ____            __                                        __                       
 /'\_/`\                        /\  _`\   __    /\ \                                      /\ \                      
/\      \    ___     ___     ___\ \ \L\ \/\_\   \ \ \         __     __  __    ___     ___\ \ \___      __   _ __   
\ \ \__\ \  / __`\  / __`\ /' _ `\ \ ,__/\/\ \   \ \ \  __  /'__`\  /\ \/\ \ /' _ `\  /'___\ \  _ `\  /'__`\/\`'__\  
 \ \ \_/\ \/\ \L\ \/\ \L\ \/\ \/\ \ \ \/  \ \ \   \ \ \L\ \/\ \L\.\_\ \ \_\ \/\ \/\ \/\ \__/\ \ \ \ \/\  __/\ \ \/    
  \ \_\\ \_\ \____/\ \____/\ \_\ \_\ \_\   \ \_\   \ \____/\ \__/.\_\\ \____/\ \_\ \_\ \____\\ \_\ \_\ \____\\ \_\    
   \/_/ \/_/\/___/  \/___/  \/_/\/_/\/_/    \/_/    \/___/  \/__/\/_/ \/___/  \/_/\/_/\/____/ \/_/\/_/\/____/ \/_/    
                                                                                                                
MOONPI
  echo "                 MoonPi Launcher v$VERSION"
  printf "%s" "${RESET}"
  echo "${YELLOW}      Plug-n-Play Moonlight Embedded Launcher${RESET}"
  echo
}
draw_cfg_banner() {
  clear
  printf "%s" "${BOLD}${BLUE}"
  cat <<'MOONPI'
                                 ____            ____                       ___                                    __                   
 /'\_/`\                        /\  _`\   __    /\  _`\                   /'___\ __                               /\ \__                
/\      \    ___     ___     ___\ \ \L\ \/\_\   \ \ \/\_\    ___     ___ /\ \__//\_\     __   __  __  _ __    __  \ \ ,_\   ___   _ __  
\ \ \__\ \  / __`\  / __`\ /' _ `\ \ ,__/\/\ \   \ \ \/_/_  / __`\ /' _ `\ \ ,__\/\ \  /'_ `\/\ \/\ \/\`'__\/'__`\ \ \ \/  / __`\/\`'__\
 \ \ \_/\ \/\ \L\ \/\ \L\ \/\ \/\ \ \ \/  \ \ \   \ \ \L\ \/\ \L\ \/\ \/\ \ \ \_/\ \ \/\ \L\ \ \ \_\ \ \ \//\ \L\.\_\ \ \_/\ \L\ \ \ \/ 
  \ \_\\ \_\ \____/\ \____/\ \_\ \_\ \_\   \ \_\   \ \____/\ \____/\ \_\ \_\ \_\  \ \_\ \____ \ \____/\ \_\\ \__/.\_\\ \__\ \____/\ \_\ 
   \/_/ \/_/\/___/  \/___/  \/_/\/_/\/_/    \/_/    \/___/  \/___/  \/_/\/_/\/_/   \/_/\/___L\ \/___/  \/_/ \/__/\/_/ \/__/\/___/  \/_/ 
                                                                                         /\____/                                        
                                                                                         \_/__/                                         

MOONPI
  echo "                 MoonPi Launcher v$VERSION"
  printf "%s" "${RESET}"
  echo "${YELLOW}      Plug-n-Play Moonlight Embedded Launcher${RESET}"
  echo
}


#— Main -----------------------------------------------------------------------

# Detect package version
PACKAGE="moonpi"
if dpkg-query -W "$PACKAGE" &> /dev/null; then
  VERSION=$(dpkg-query -W -f='${Version}' "$PACKAGE")
else
  VERSION="1.0"
fi

# Load config
read_config

# Ensure a user config file exists (created from system defaults if missing)
ensure_user_cfg

# Rebuild custom resolution flags if config was saved with a custom resolution
if [[ -z "${RESOLUTION_FLAG:-}" && -n "${CUSTOM_WIDTH:-}" && -n "${CUSTOM_HEIGHT:-}" ]]; then
  width_flag=(-width "$CUSTOM_WIDTH")
  height_flag=(-height "$CUSTOM_HEIGHT")
fi

while true; do
  draw_banner
  echo "${GREEN} 1)${RESET} Launch MoonPi"
  echo "${GREEN} 2)${RESET} Configure MoonPi"
  echo "${GREEN} 3)${RESET} Pair Moonlight"
  echo "${GREEN} 4)${RESET} Exit to Console"
  
  # show desktop option if a compositor/X server is running (covers Bookworm/labwc and older/Xorg)
  if pgrep -x labwc >/dev/null 2>&1 || pgrep -x wayfire >/dev/null 2>&1 || \
     pgrep -x weston >/dev/null 2>&1 || pgrep -x Xorg   >/dev/null 2>&1; then
    echo "${GREEN} 5)${RESET} Launch Desktop"
    MAX_OPTION=5
  else
    MAX_OPTION=4
  fi

  read -p "${BLUE}Choose [1–${MAX_OPTION}, default:1]: ${RESET}" action
   action=${action:-1}

  case $action in
    1)
      # build argument list, only include flags if vars are set
      args=("$HOST_IP")

      [[ -n "${APP_NAME:-}" ]] \
        && args+=(-app "$APP_NAME")

      if [[ -n "${RESOLUTION_FLAG:-}" ]]; then
        args+=("$RESOLUTION_FLAG")
      elif [[ ${#width_flag[@]} -gt 0 && ${#height_flag[@]} -gt 0 ]]; then
        args+=("${width_flag[@]}" "${height_flag[@]}")
      fi

      [[ -n "${FPS:-}" ]] \
        && args+=(-fps "$FPS")

      [[ -n "${BITRATE:-}" ]] \
        && args+=(-bitrate "$BITRATE")

      [[ "${LOCAL_AUDIO:-}" == "yes" ]] \
        && args+=(-localaudio)

      # hand off to moonpi-safe with filtered args
      moonpi-safe "${args[@]}"
      ;;
    2)
      configurator
      ;;
    3)
      pair_moonlight
      ;;
    4)
      echo "${BLUE}Switching to VT1…${RESET}"
      sleep 3
      chvt 1
      ;;
    5)
      # only valid when MAX_OPTION=5
      echo "${BLUE}Switching to desktop…${RESET}"
      sleep 3
      chvt 7
      ;;
    *)
      echo "${YELLOW}Invalid: '$action'${RESET}"
      echo "Returning to menu in 3 seconds…"
      sleep 3
      ;;
  esac
done