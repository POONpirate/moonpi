# MoonPi local dev overrides
# Copy this file to .env and fill in your values — .env is gitignored.

# SSH user on the Windows machine hosting the source
DEFAULT_REMOTE_USER="moonpi"

# IP address of the Windows machine
DEFAULT_REMOTE_HOST="192.168.0.2"

# Path to the moonpi working directory on the Windows machine
DEFAULT_REMOTE_PATH="/Users/x/Documents/moonpi"
