# lintian overrides
debian/moonpi.lintian-overrides                 usr/share/lintian/overrides/

# configuration
etc/moonpi/moonpi.conf                         etc/moonpi/

# binaries
usr/bin/moonpi                                  usr/bin/
usr/bin/moonpi-safe                             usr/bin/

# systemd units
usr/lib/systemd/system/moonpi@.service          usr/lib/systemd/system/

# desktop shortcut
usr/share/applications/moonpi.desktop                usr/share/applications/

# icon
usr/share/icons/hicolor/64x64/apps/moonpi.png        usr/share/icons/hicolor/64x64/apps/

# manpages
usr/share/man/man1/moonpi.1                     usr/share/man/man1/
usr/share/man/man1/moonpi-safe.1                usr/share/man/man1/
