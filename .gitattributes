# Normalize all text files to LF so SCP/rsync to Linux works cleanly
* text=auto eol=lf

# Explicitly enforce LF for files git might not auto-detect as text
*.sh       text eol=lf
*.conf     text eol=lf
*.md       text eol=lf
*.service  text eol=lf
*.install  text eol=lf
*.preset   text eol=lf
*.1        text eol=lf
DEBIAN/control    text eol=lf
DEBIAN/copyright  text eol=lf
DEBIAN/rules      text eol=lf
DEBIAN/postinst   text eol=lf
DEBIAN/preinst    text eol=lf
DEBIAN/prerm      text eol=lf
usr/bin/moonpi       text eol=lf
usr/bin/moonpi-safe  text eol=lf

# Binary files — never touch line endings
*.deb   binary
*.gz    binary
*.png   binary
*.jpg   binary